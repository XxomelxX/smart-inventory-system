datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Product {
  id        Int     @id @default(autoincrement())
  sku       String  @unique
  name      String
  price     Float
  stock     Int
  barcode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  OrderItem OrderItem[]
}

model Order {
  id         Int         @id @default(autoincrement())
  items      OrderItem[]
  total      Float
  payment    String
  paymentRef String?
  tendered   Float?
  change     Float?
  cashier    String?
  createdAt  DateTime @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  price     Float
}

model AuditLog {
  id        Int     @id @default(autoincrement())
  user      String
  action    String
  details   String
  createdAt DateTime @default(now())
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  passwordHash String
  role         String  @default("cashier")
  createdAt    DateTime @default(now())
}
